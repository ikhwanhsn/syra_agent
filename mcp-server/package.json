{
  "name": "@syra/mcp-server",
  "version": "0.4.0",
  "description": "MCP server exposing Syra x402 API tools with auto-pay and full agentTools catalog",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "syra-mcp": "dist/index.js"
  },
  "scripts": {
    "sync:mcp-tools": "node ../scripts/sync-mcp-tools.mjs",
    "prebuild": "npm run sync:mcp-tools",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@syra/sdk": "file:../syra-sdk",
    "@solana/kit": "^5.5.1",
    "@x402-avm/avm": "^2.6.1",
    "@x402-avm/core": "^2.6.1",
    "@x402-avm/fetch": "^2.6.1",
    "@x402/core": "^2.2.0",
    "@x402/evm": "^2.2.0",
    "@x402/extensions": "^2.16.0",
    "@x402/fetch": "^2.3.0",
    "@x402/svm": "^2.2.0",
    "bs58": "^6.0.0",
    "viem": "^2.31.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
