{
  "name": "@syra-ai/mcp-server",
  "version": "0.4.1",
  "description": "MCP server exposing Syra x402 API tools with auto-pay and full agentTools catalog",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "syra-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "sync:mcp-tools": "node ../scripts/sync-mcp-tools.mjs",
    "prebuild": "npm run sync:mcp-tools",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/syra-agent/syra-monorepo",
    "directory": "mcp-server"
  },
  "keywords": ["syra", "mcp", "x402", "solana", "agents", "model-context-protocol"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@syra-ai/sdk": "^0.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
