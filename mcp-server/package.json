{
  "name": "@syra-ai/mcp-server",
  "version": "0.4.2",
  "description": "MCP server for Syra machine money — 240+ crypto research & agent tools with x402 auto-pay for Cursor, Claude Desktop, and agent frameworks.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "syra-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "sync:mcp-tools": "node ../scripts/sync-mcp-tools.mjs",
    "prebuild": "npm run sync:mcp-tools",
