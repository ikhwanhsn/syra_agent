{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "baseUrl": "https://api.syraa.fun",
  "description": "Direct x402 HTTP tools match GET https://api.syraa.fun/.well-known/x402. For Exa, crawl, browser-use, Nansen, Zerion, pump.fun, 8004 reads, and other partner tools, use GET /agent/tools (list ids) and POST /agent/tools/call (body: anonymousId, toolId, params).",
  "tools": [
    {
      "id": "health",
      "name": "API health",
      "description": "Liveness / connectivity (x402).",
      "method": "GET",
      "path": "/health",
      "parameters": [],
      "priceUsd": 0.0001
    },
    {
      "id": "mpp-v1-health",
      "name": "MPP health (x402)",
      "description": "MPP-branded health; same tier as /health.",
      "method": "GET",
      "path": "/mpp/v1/health",
      "parameters": [],
      "priceUsd": 0.0001
    },
    {
      "id": "news",
      "name": "Crypto news",
      "description": "Latest crypto news (optional ticker).",
      "method": "GET",
      "path": "/news",
      "parameters": [
        { "name": "ticker", "in": "query", "required": false, "description": "BTC, ETH, SOL, or general" }
      ],
      "priceUsd": 0.01
    },
    {
      "id": "signal",
      "name": "Trading signal",
      "description": "OHLC + technical signal.",
      "method": "GET",
      "path": "/signal",
      "parameters": [
        { "name": "token", "in": "query", "required": false, "description": "e.g. bitcoin, solana" }
      ],
      "priceUsd": 0.01
    },
    {
      "id": "sentiment",
      "name": "Sentiment",
      "description": "Market sentiment analysis.",
      "method": "GET",
      "path": "/sentiment",
      "parameters": [
        { "name": "ticker", "in": "query", "required": false, "description": "Ticker or general" }
      ],
      "priceUsd": 0.01
    },
    {
      "id": "event",
      "name": "Events",
      "description": "Crypto events feed.",
      "method": "GET",
      "path": "/event",
      "parameters": [
        { "name": "ticker", "in": "query", "required": false, "description": "Ticker or general" }
      ],
      "priceUsd": 0.01
    },
    {
      "id": "trending-headline",
      "name": "Trending headlines",
      "description": "Trending crypto headlines.",
      "method": "GET",
      "path": "/trending-headline",
      "parameters": [
        { "name": "ticker", "in": "query", "required": false, "description": "Ticker or general" }
      ],
      "priceUsd": 0.01
    },
    {
      "id": "sundown-digest",
      "name": "Sundown digest",
      "description": "Daily roundup.",
      "method": "GET",
      "path": "/sundown-digest",
      "parameters": [],
      "priceUsd": 0.01
    },
    {
      "id": "brain",
      "name": "Syra Brain",
      "description": "Natural-language Q&A; may orchestrate tools server-side.",
      "method": "POST",
      "path": "/brain",
      "parameters": [
        { "name": "question", "in": "body", "required": true, "description": "Question string" }
      ],
      "priceUsd": 0.01
    },
    {
      "id": "arbitrage",
      "name": "Arbitrage snapshot",
      "description": "CMC top + cross-CEX spread view.",
      "method": "GET",
      "path": "/arbitrage",
      "parameters": [
        { "name": "limit", "in": "query", "required": false, "description": "1–25 (default 10)" }
      ],
      "priceUsd": 0.04
    },
    {
      "id": "analytics-summary",
      "name": "Analytics summary",
      "description": "Bundled analytics (Jupiter, Nansen smart money, Binance correlation, etc.).",
      "method": "GET",
      "path": "/analytics/summary",
      "parameters": [],
      "priceUsd": 0.01
    },
    {
      "id": "x",
      "name": "X (Twitter) search",
      "description": "X search / feed proxy (x402).",
      "method": "GET",
      "path": "/x",
      "parameters": [],
      "priceUsd": 0.01
    },
    {
      "id": "agent-tools-call",
      "name": "Agent tool call (migrated + partner tools)",
      "description": "POST body: { anonymousId, toolId, params? }. List tool ids: GET /agent/tools. Use for exa-search, website-crawl, browser-use, jupiter-swap-order, Nansen, Zerion, etc.",
      "method": "POST",
      "path": "/agent/tools/call",
      "parameters": [
        { "name": "anonymousId", "in": "body", "required": true, "description": "User session id" },
        { "name": "toolId", "in": "body", "required": true, "description": "From GET /agent/tools" },
        { "name": "params", "in": "body", "required": false, "description": "Tool-specific key/value" }
      ],
      "priceUsd": 0
    }
  ]
}
