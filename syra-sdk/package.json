{
  "name": "@syra-ai/sdk",
  "version": "0.2.2",
  "description": "Typed TypeScript client for Syra machine money — x402 pay-per-call APIs, auto-pay wallets, and agent treasury on Solana, Base & Algorand.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./payment": {
      "types": "./dist/payment/index.d.ts",
      "import": "./dist/payment/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikhwanhsn/syra_agent.git",
    "directory": "syra-sdk"
  },
  "homepage": "https://github.com/ikhwanhsn/syra_agent/tree/main/syra-sdk#readme",
  "bugs": {
    "url": "https://github.com/ikhwanhsn/syra_agent/issues"
  },
  "keywords": [
    "syra",
    "x402",
    "http-402",
    "solana",
    "base",
    "algorand",
    "agents",
    "mcp",
    "machine-money",
    "trading",
    "api",
    "usdc",
    "micropayments",
    "typescript",
    "typescript-sdk"
  ],
  "author": "Syra",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@solana/kit": "^5.5.1",
    "@x402-avm/avm": "^2.6.1",
    "@x402-avm/core": "^2.6.1",
    "@x402-avm/fetch": "^2.6.1",
    "@x402/core": "^2.2.0",
    "@x402/evm": "^2.2.0",
    "@x402/extensions": "^2.16.0",
    "@x402/fetch": "^2.3.0",
    "@x402/svm": "^2.2.0",
    "bs58": "^6.0.0",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.6.3"
  }
}
